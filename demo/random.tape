Output random.gif

Set Shell "bash"
Set FontSize 22
Set Width 1400
Set Height 700
Set Padding 30
Set Theme "Catppuccin Mocha"
Set TypingSpeed 35ms
Set FontFamily "Menlo"
Set Framerate 30

Sleep 500ms

Type "runit add tip 'echo Commit often' 'echo Write tests first' 'echo Take a break' --mode random"
Enter
Sleep 1200ms

Type "runit tip"
Enter
Sleep 1200ms

Type "runit tip"
Enter
Sleep 1200ms

Type "runit tip"
Enter
Sleep 2000ms
